<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AutoClicker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoClicker"
    Title="AutoClicker">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Spacing="16" MaxWidth="500">

            <!-- Interval Section -->
            <TextBlock Text="Click Interval" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="8" RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Hours" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBlock Text="Minutes" Grid.Column="1" HorizontalAlignment="Center"/>
                <TextBlock Text="Seconds" Grid.Column="2" HorizontalAlignment="Center"/>
                <TextBlock Text="Milliseconds" Grid.Column="3" HorizontalAlignment="Center"/>

                <NumberBox x:ConnectionId='20' x:Name="HoursBox" Grid.Column="0" Grid.Row="1"
                           Minimum="0" Maximum="999" SpinButtonPlacementMode="Compact"
                                                         />
                <NumberBox x:ConnectionId='21' x:Name="MinutesBox" Grid.Column="1" Grid.Row="1"
                           Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact"
                                                         />
                <NumberBox x:ConnectionId='22' x:Name="SecondsBox" Grid.Column="2" Grid.Row="1"
                           Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact"
                                                         />
                <NumberBox x:ConnectionId='23' x:Name="MillisecondsBox" Grid.Column="3" Grid.Row="1"
                           Minimum="0" Maximum="999" SpinButtonPlacementMode="Compact"
                                                         />
            </Grid>

            <MenuFlyoutSeparator/>

            <!-- Mouse Button Section -->
            <TextBlock Text="Mouse Button" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <ComboBox x:ConnectionId='2' x:Name="MouseButtonCombo" SelectedIndex="0"                                      >
                <ComboBoxItem Content="Left Click"/>
                <ComboBoxItem Content="Right Click"/>
                <ComboBoxItem Content="Middle Click"/>
            </ComboBox>

            <MenuFlyoutSeparator/>

            <!-- Click Location Section -->
            <TextBlock Text="Click Location" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <RadioButtons x:ConnectionId='3' x:Name="LocationModeRadio"                                       >
                <RadioButton Content="Current Mouse Position" Tag="MousePosition" IsChecked="True"/>
                <RadioButton Content="Predetermined Locations" Tag="Predetermined"/>
            </RadioButtons>

            <StackPanel x:ConnectionId='4' x:Name="LocationsPanel" Visibility="Collapsed" Spacing="8">
                <ListView x:ConnectionId='15' x:Name="LocationsList" MaxHeight="150"
                          SelectionMode="Single" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1" CornerRadius="4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ToggleButton x:ConnectionId='17' x:Name="ChooseLocationToggle" Content="Choose Location"
                                                                    />
                    <Button x:ConnectionId='18' Content="Remove Selected"                             />
                </StackPanel>

                <TextBlock x:ConnectionId='16' x:Name="LocationInstructions"
                           Text="Click the toggle, then click anywhere on screen to add location"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>

            <MenuFlyoutSeparator/>

            <!-- Iteration Section -->
            <TextBlock Text="Iterations" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <RadioButtons x:ConnectionId='5' x:Name="IterationModeRadio"                                        >
                <RadioButton Content="Repeat Indefinitely" Tag="Indefinite" IsChecked="True"/>
                <RadioButton Content="Set Number of Clicks" Tag="SetCount"/>
            </RadioButtons>

            <StackPanel x:ConnectionId='6' x:Name="IterationCountPanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="Number of clicks:" VerticalAlignment="Center"/>
                <NumberBox x:ConnectionId='14' x:Name="IterationCountBox" Minimum="1" Maximum="999999" Value="10"
                           SpinButtonPlacementMode="Compact"                                     />
            </StackPanel>

            <MenuFlyoutSeparator/>

            <!-- Toggle Key Section -->
            <TextBlock Text="Toggle Hotkey" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:ConnectionId='12' x:Name="ToggleKeyText" Text="Insert" VerticalAlignment="Center"
                           FontWeight="SemiBold" FontSize="16"/>
                <Button x:ConnectionId='13' x:Name="RebindButton" Content="Rebind"                           />
            </StackPanel>
            <TextBlock x:ConnectionId='7' x:Name="RebindInstructions"
                       Text="Press any key to set as new toggle hotkey..."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

            <MenuFlyoutSeparator/>

            <!-- Configuration Section -->
            <TextBlock Text="Configuration" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:ConnectionId='10' Content="Save Config"                         />
                <Button x:ConnectionId='11' Content="Load Config"                         />
            </StackPanel>

            <MenuFlyoutSeparator/>

            <!-- Start/Stop Button -->
            <Button x:ConnectionId='8' x:Name="StartStopButton" Content="Start (Insert)"
                                            HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}" Height="48"
                    FontSize="16"/>

            <!-- Status -->
            <TextBlock x:ConnectionId='9' x:Name="StatusText" Text="Stopped"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

        </StackPanel>
    </ScrollViewer>
</Window>

