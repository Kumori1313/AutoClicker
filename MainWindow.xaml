<Window x:Class="AutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoClicker" Height="650" Width="450"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <StackPanel Margin="5">

            <!-- Interval Section -->
            <TextBlock Text="Click Interval" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Hours" Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Minutes" Grid.Column="1" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Seconds" Grid.Column="2" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Milliseconds" Grid.Column="3" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                <TextBox x:Name="HoursBox" Grid.Column="0" Grid.Row="1" Margin="2" Text="0"
                         TextChanged="IntervalChanged" HorizontalContentAlignment="Center"/>
                <TextBox x:Name="MinutesBox" Grid.Column="1" Grid.Row="1" Margin="2" Text="0"
                         TextChanged="IntervalChanged" HorizontalContentAlignment="Center"/>
                <TextBox x:Name="SecondsBox" Grid.Column="2" Grid.Row="1" Margin="2" Text="1"
                         TextChanged="IntervalChanged" HorizontalContentAlignment="Center"/>
                <TextBox x:Name="MillisecondsBox" Grid.Column="3" Grid.Row="1" Margin="2" Text="0"
                         TextChanged="IntervalChanged" HorizontalContentAlignment="Center"/>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- Mouse Button Section -->
            <TextBlock Text="Mouse Button" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <ComboBox x:Name="MouseButtonCombo" SelectedIndex="0" SelectionChanged="MouseButtonChanged">
                <ComboBoxItem Content="Left Click"/>
                <ComboBoxItem Content="Right Click"/>
                <ComboBoxItem Content="Middle Click"/>
            </ComboBox>

            <Separator Margin="0,12"/>

            <!-- Click Location Section -->
            <TextBlock Text="Click Location" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel>
                <RadioButton x:Name="MousePositionRadio" Content="Current Mouse Position"
                             IsChecked="True" Checked="LocationModeChanged" Margin="0,2"/>
                <RadioButton x:Name="PredeterminedRadio" Content="Predetermined Locations"
                             Checked="LocationModeChanged" Margin="0,2"/>
            </StackPanel>

            <StackPanel x:Name="LocationsPanel" Visibility="Collapsed" Margin="0,8,0,0">
                <ListBox x:Name="LocationsList" Height="100" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="ChooseLocationToggle" Content="Choose Location"
                                  Width="110" Click="ChooseLocationToggle_Click"/>
                    <Button Content="Remove Selected" Margin="8,0,0,0"
                            Width="110" Click="RemoveLocation_Click"/>
                </StackPanel>

                <TextBlock x:Name="LocationInstructions"
                           Text="Click the toggle, then click anywhere on screen to add location"
                           Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <Separator Margin="0,12"/>

            <!-- Iteration Section -->
            <TextBlock Text="Iterations" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel>
                <RadioButton x:Name="IndefiniteRadio" Content="Repeat Indefinitely"
                             IsChecked="True" Checked="IterationModeChanged" Margin="0,2"/>
                <RadioButton x:Name="SetCountRadio" Content="Set Number of Clicks"
                             Checked="IterationModeChanged" Margin="0,2"/>
            </StackPanel>

            <StackPanel x:Name="IterationCountPanel" Orientation="Horizontal"
                        Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock Text="Number of clicks:" VerticalAlignment="Center"/>
                <TextBox x:Name="IterationCountBox" Text="10" Width="80" Margin="8,0,0,0"
                         TextChanged="IterationCountChanged" HorizontalContentAlignment="Center"/>
            </StackPanel>

            <Separator Margin="0,12"/>

            <!-- Toggle Key Section -->
            <TextBlock Text="Toggle Hotkey" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToggleKeyText" Text="Insert" VerticalAlignment="Center"
                           FontWeight="SemiBold" FontSize="14" Width="80"/>
                <Button x:Name="RebindButton" Content="Rebind" Width="80" Click="RebindButton_Click"/>
            </StackPanel>
            <TextBlock x:Name="RebindInstructions"
                       Text="Press any key to set as new toggle hotkey..."
                       Foreground="Gray" Margin="0,4,0,0" Visibility="Collapsed"/>

            <Separator Margin="0,12"/>

            <!-- Configuration Section -->
            <TextBlock Text="Configuration" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>

            <TextBlock Text="Settings File Path:" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ConfigPathBox" Grid.Column="0" IsReadOnly="True"
                         VerticalContentAlignment="Center" Padding="4,2"/>
                <Button x:Name="BrowseConfigButton" Content="Browse..." Grid.Column="1"
                        Width="70" Margin="8,0,0,0" Click="BrowseConfigPath_Click"/>
            </Grid>

            <StackPanel Orientation="Horizontal">
                <Button Content="Save Config" Width="100" Click="SaveConfig_Click"/>
                <Button Content="Load Config" Width="100" Margin="8,0,0,0" Click="LoadConfig_Click"/>
            </StackPanel>

            <Separator Margin="0,12"/>

            <!-- Start/Stop Button -->
            <Button x:Name="StartStopButton" Content="Start (Insert)"
                    Click="StartStop_Click" Height="40" FontSize="14" FontWeight="SemiBold"/>

            <!-- Status -->
            <TextBlock x:Name="StatusText" Text="Stopped" Margin="0,8,0,0"
                       HorizontalAlignment="Center" Foreground="Gray"/>

        </StackPanel>
    </ScrollViewer>
</Window>
